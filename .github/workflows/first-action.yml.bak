name: GH200 Python CI Pipeline

on:
  push:
    branches: [ "main" ]

jobs:
  ci_quality_checks:
    name: Run Lint, Tests & Coverage
    runs-on: ubuntu-latest

    steps:
      - name: Get code
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.11"

      - name: Install Poetry
        run: pip install poetry

      - name: Install Dependencies
        run: poetry install

      - name: Lint (Ruff)
        run: poetry run ruff check .

      - name: Format Check (Black)
        run: poetry run black --check .

      - name: Tests + Coverage
        run: poetry run pytest --cov=src --cov-fail-under=85


  deploy:
    name: Deploy Application
    runs-on: ubuntu-latest
    needs: ci_quality_checks   # (runs only if CI passes)

    steps:
      - name: Get code
        uses: actions/checkout@v4

      - name: Simulate Deployment
        run: |
          echo "Deploying GH200 application..."
          echo "Deployment successful!"