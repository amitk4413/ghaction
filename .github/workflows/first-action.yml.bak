name: GH200 Python CI Pipeline

on:
  push:

jobs:
  CI Quality Checks (Lint + Test + Coverage):
    runs-on: ubuntu-latest

    steps:
      - name: Get code
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.11"

      - name: Install Poetry
        run: |
          pip install poetry

      - name: Install Dependencies
        run: |
          poetry install

      - name: Run Linting (ruff)
        run: poetry run ruff check .

      - name: Run Formatting (black)
        run: poetry run black --check .

      - name: Run tests with coverage
        run: poetry run pytest --cov=src --cov-report=term-missing --cov-fail-under=90